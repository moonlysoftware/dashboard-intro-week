{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel (Sail)",
      "runtimeExecutable": "vendor/bin/sail",
      "runtimeArgs": ["up"],
      "port": 8080,
      "autoPort": false,
      "attachToExisting": true
    },
    {
      "name": "Laravel (standalone)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve"],
      "port": 8000
    },
    {
      "name": "Vite",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Queue Worker",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1", "--timeout=0"],
      "port": null
    },
    {
      "name": "Pail (Logs)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "pail", "--timeout=0"],
      "port": null
    }
  ]
}
